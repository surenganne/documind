# DocuMind — Environment Variables Example
# Copy this file to .env and fill in your values. Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5440/documind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret

# ── AWS ───────────────────────────────────────────────────────────────────────
# Local development only: set AWS_PROFILE to your SSO profile name.
# The ~/.aws directory is mounted into containers in docker-compose.dev.yml.
# Production deployments use the EC2 instance role (or ECS task role) via IMDS —
# no AWS credential variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, etc.)
# are required or injected in production.
AWS_PROFILE=your-sso-profile-name
AWS_REGION=us-east-1

# ── S3 / File Storage ─────────────────────────────────────────────────────────
S3_BUCKET=your-documind-bucket
S3_LOCAL_FALLBACK_PATH=/data/uploads
# LocalStack: set AWS_ENDPOINT_URL to route S3 calls to LocalStack in dev.
# Leave unset in production (uses real AWS S3).
# AWS_ENDPOINT_URL=http://localhost:4566

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5180,http://localhost:8080

# ── Auth Token Expiry ─────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
