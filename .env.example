# DocuMind — Environment Variables Example
# Copy this file to .env and fill in your values. Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://documind:documind@localhost:5440/documind

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret

# ── AWS ───────────────────────────────────────────────────────────────────────
# For local development with AWS SSO:
# 1. Configure AWS SSO: aws configure sso
# 2. Set your SSO profile name below
# 3. Login: aws sso login --profile your-sso-profile-name
# The ~/.aws directory will be mounted into Docker containers for credential access.
AWS_PROFILE=your-sso-profile-name
AWS_REGION=us-east-1
AWS_BEDROCK_REGION=us-east-1

# ── S3 / File Storage ─────────────────────────────────────────────────────────
# S3 bucket for document storage (create this bucket in your AWS account)
# Suggested name: documind-dev-<your-name> or documind-<environment>
# Note: S3 uses AWS_REGION, Bedrock uses AWS_BEDROCK_REGION (can be different)
S3_BUCKET=documind-app-storage-2026

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5180,http://localhost:8080

# ── Auth Token Expiry ─────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
